APP_NAME=StudyTrackPro
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-dominio.com

# Obrigatório atrás de reverse proxy (Docker bridge: rede interna do compose ou IP do Nginx).
TRUSTED_PROXIES=*

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

REDIS_HOST=
# Use senha forte; nunca "null" literal em produção.
REDIS_PASSWORD=
REDIS_PORT=6379

CACHE_STORE=redis
CACHE_DATABASE=1
QUEUE_CONNECTION=redis
REDIS_QUEUE_DATABASE=2
SESSION_DRIVER=redis
REDIS_SESSION_DATABASE=3
REDIS_HORIZON_DATABASE=4

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=seu-dominio.com
REVERB_PORT=443
REVERB_SCHEME=https

VITE_API_URL=https://seu-dominio.com
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=seu-dominio.com
VITE_REVERB_PORT=443

SANCTUM_STATEFUL_DOMAINS=seu-dominio.com
SESSION_DOMAIN=.seu-dominio.com
# Cookie só em HTTPS (por defeito já é true com APP_ENV=production)
SESSION_SECURE_COOKIE=true

# Expiração token API (minutos)
SANCTUM_EXPIRATION=1440

# CORS: URL do frontend (ex: https://app.seu-dominio.com)
CORS_ALLOWED_ORIGINS=https://app.seu-dominio.com

# Emails (separados por vírgula) que podem acessar /horizon (sessão web + utilizador autenticado).
HORIZON_ADMIN_EMAILS=admin@seu-dominio.com
# Opcional: restringe Horizon a IPs (ex.: VPN ou bastion). Vazio = sem filtro por IP.
# HORIZON_ALLOWED_IPS=203.0.113.10
