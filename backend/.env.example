# =============================================================================
# StudyTrackPro - Variáveis de ambiente
# Copie para .env e ajuste. Em produção: APP_DEBUG=false, HTTPS, senhas fortes.
# =============================================================================

APP_NAME=StudyTrackPro
APP_ENV=local
# Gere uma chave após copiar para .env: php artisan key:generate
APP_KEY=
# PRODUÇÃO: use APP_DEBUG=false (evita vazamento de stack trace e variáveis sensíveis)
APP_DEBUG=true
# PRODUÇÃO: use HTTPS (ex: https://api.seu-dominio.com)
APP_URL=http://localhost

# IPs dos proxies (Nginx, load balancer). Necessário para HTTPS e rate limit corretos.
# Ex.: TRUSTED_PROXIES=*  ou  TRUSTED_PROXIES=10.0.0.0/8,172.28.0.0/16
# TRUSTED_PROXIES=

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=studytrack
DB_USERNAME=studytrack
# PRODUÇÃO: use senha forte (nunca "secret"); gere com: openssl rand -base64 32
DB_PASSWORD=secret

REDIS_HOST=redis
# Deve ser igual ao requirepass definido em docker/redis/redis.conf
# Valor padrão de dev: c812c3a3c4685cda4fc087d6d4edf667
# PRODUÇÃO: troque por uma senha gerada com: openssl rand -hex 32
REDIS_PASSWORD=c812c3a3c4685cda4fc087d6d4edf667
REDIS_PORT=6379

# CACHE_STORE=redis: rate limit compartilhado entre workers; cache tags; throttle usa Redis
CACHE_STORE=redis
CACHE_DATABASE=1
QUEUE_CONNECTION=redis
REDIS_QUEUE_DATABASE=2
SESSION_DRIVER=redis
REDIS_SESSION_DATABASE=3
# Nome do cookie de sessão (deve coincidir com SESSION_COOKIE_NAME no Nginx, ex. docker-compose)
SESSION_COOKIE=studytrack_session
REDIS_HORIZON_DATABASE=4

REVERB_APP_ID=studytrack
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_API_URL=http://localhost
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080

# Host:porta do frontend SPA (Vite dev). Inclua a porta para SameSite/cookies stateful.
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:5173,127.0.0.1:5173

# Expiração tokens API (minutos). Comentário: omitir mantém 1440.
# SANCTUM_EXPIRATION=1440

# CORS: origens permitidas separadas por vírgula (com CORS_ALLOWED_ORIGINS preenchido o backend activa supports_credentials para cookies Sanctum)
# Dev local (Vite dev server): http://localhost:5173
# PRODUÇÃO: substitua pela URL real do frontend (ex: https://app.seu-dominio.com)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Em produção: emails separados por vírgula que podem acessar /horizon (requer sessão web).
# HORIZON_ADMIN_EMAILS=admin@example.com,demo@studytrack.local
# Opcional: só estes IPs podem abrir Horizon (vazio = sem filtro extra). Ex.: HORIZON_ALLOWED_IPS=127.0.0.1,10.0.0.5
# HORIZON_ALLOWED_IPS=
