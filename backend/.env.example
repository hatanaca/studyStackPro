# =============================================================================
# StudyTrackPro - Variáveis de ambiente
# Copie para .env e ajuste. Em produção: APP_DEBUG=false, HTTPS, senhas fortes.
# =============================================================================

APP_NAME=StudyTrackPro
APP_ENV=local
# Gere uma chave após copiar para .env: php artisan key:generate
APP_KEY=
# PRODUÇÃO: use APP_DEBUG=false (evita vazamento de stack trace e variáveis sensíveis)
APP_DEBUG=true
# PRODUÇÃO: use HTTPS (ex: https://api.seu-dominio.com)
APP_URL=http://localhost

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=studytrack
DB_USERNAME=studytrack
# PRODUÇÃO: use senha forte (nunca "secret"); gere com: openssl rand -base64 32
DB_PASSWORD=secret

REDIS_HOST=redis
# Deve ser igual ao requirepass definido em docker/redis/redis.conf
# Valor padrão de dev: c812c3a3c4685cda4fc087d6d4edf667
# PRODUÇÃO: troque por uma senha gerada com: openssl rand -hex 32
REDIS_PASSWORD=c812c3a3c4685cda4fc087d6d4edf667
REDIS_PORT=6379

# CACHE_STORE=redis: rate limit compartilhado entre workers; cache tags; throttle usa Redis
CACHE_STORE=redis
CACHE_DATABASE=1
QUEUE_CONNECTION=redis
REDIS_QUEUE_DATABASE=2
SESSION_DRIVER=redis
REDIS_SESSION_DATABASE=3
REDIS_HORIZON_DATABASE=4

REVERB_APP_ID=studytrack
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_API_URL=http://localhost
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# CORS: origens permitidas separadas por vírgula
# Dev local (Vite dev server): http://localhost:5173
# PRODUÇÃO: substitua pela URL real do frontend (ex: https://app.seu-dominio.com)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Em produção: emails separados por vírgula que podem acessar /horizon
# HORIZON_ADMIN_EMAILS=admin@example.com,demo@studytrack.local
