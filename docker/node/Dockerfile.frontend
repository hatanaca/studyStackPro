FROM node:20-alpine

WORKDIR /app

# Copiar package files (context = frontend/)
COPY package*.json ./

# Instalar dependências
RUN npm ci

# Copiar resto do código (será sobrescrito por volume em dev)
COPY . .

# Expor porta do Vite
EXPOSE 5173

# Comando default: dev server
CMD ["npm", "run", "dev"]
