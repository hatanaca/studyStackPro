FROM node:22-alpine

WORKDIR /app

# Copiar package files (context = frontend/)
COPY package*.json ./

# Dependências + auditoria (flatted, cross-spawn, socket.io-parser, etc. — ver scan Docker).
RUN npm ci
RUN npm audit fix

# Copiar resto do código (será sobrescrito por volume em dev)
COPY . .

# Expor porta do Vite
EXPOSE 5173

# Comando default: dev server
CMD ["npm", "run", "dev"]
