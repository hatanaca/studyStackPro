{
  "info": {
    "name": "StudyTrack Pro API",
    "description": "Coleção Postman da API StudyTrack Pro v1 (base_url = /api/v1). Health em /api/health.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost/api/v1" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        { "name": "Register", "request": { "method": "POST", "url": "{{base_url}}/auth/register", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}" } },
        { "name": "Login", "request": { "method": "POST", "url": "{{base_url}}/auth/login", "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}" } },
        { "name": "Logout", "request": { "method": "POST", "url": "{{base_url}}/auth/logout" } },
        { "name": "Me", "request": { "method": "GET", "url": "{{base_url}}/auth/me" } },
        { "name": "Update Profile", "request": { "method": "PUT", "url": "{{base_url}}/auth/me", "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Name\",\n  \"timezone\": \"America/Sao_Paulo\"\n}" } },
        { "name": "Change Password", "request": { "method": "POST", "url": "{{base_url}}/auth/change-password", "body": { "mode": "raw", "raw": "{\n  \"current_password\": \"password123\",\n  \"password\": \"newpassword123\",\n  \"password_confirmation\": \"newpassword123\"\n}" } },
        { "name": "List Tokens", "request": { "method": "GET", "url": "{{base_url}}/auth/tokens" } },
        { "name": "Revoke All Tokens", "request": { "method": "DELETE", "url": "{{base_url}}/auth/tokens" } }
      ]
    },
    {
      "name": "Technologies",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/technologies" } },
        { "name": "Create", "request": { "method": "POST", "url": "{{base_url}}/technologies", "body": { "mode": "raw", "raw": "{\n  \"name\": \"JavaScript\",\n  \"color\": \"#F7DF1E\"\n}" } },
        { "name": "Show", "request": { "method": "GET", "url": "{{base_url}}/technologies/{{tech_id}}" } },
        { "name": "Update", "request": { "method": "PUT", "url": "{{base_url}}/technologies/{{tech_id}}", "body": { "mode": "raw", "raw": "{\n  \"name\": \"TypeScript\",\n  \"color\": \"#3178C6\"\n}" } },
        { "name": "Delete", "request": { "method": "DELETE", "url": "{{base_url}}/technologies/{{tech_id}}" } },
        { "name": "Search", "request": { "method": "GET", "url": "{{base_url}}/technologies/search?q=java" } }
      ]
    },
    {
      "name": "Study Sessions",
      "item": [
        { "name": "List", "request": { "method": "GET", "url": "{{base_url}}/study-sessions" } },
        { "name": "Create", "request": { "method": "POST", "url": "{{base_url}}/study-sessions", "body": { "mode": "raw", "raw": "{\n  \"technology_id\": \"{{tech_id}}\",\n  \"started_at\": \"2025-01-15T10:00:00Z\",\n  \"ended_at\": \"2025-01-15T11:30:00Z\",\n  \"notes\": \"Sessão de estudo\"\n}" } },
        { "name": "Show", "request": { "method": "GET", "url": "{{base_url}}/study-sessions/{{session_id}}" } },
        { "name": "Update (PUT)", "request": { "method": "PUT", "url": "{{base_url}}/study-sessions/{{session_id}}", "body": { "mode": "raw", "raw": "{\n  \"technology_id\": \"{{tech_id}}\",\n  \"started_at\": \"2025-01-15T10:00:00Z\",\n  \"ended_at\": \"2025-01-15T12:00:00Z\"\n}" } },
        { "name": "Update (PATCH)", "request": { "method": "PATCH", "url": "{{base_url}}/study-sessions/{{session_id}}", "body": { "mode": "raw", "raw": "{\n  \"notes\": \"Notas atualizadas\"\n}" } },
        { "name": "Delete", "request": { "method": "DELETE", "url": "{{base_url}}/study-sessions/{{session_id}}" } },
        { "name": "Start", "request": { "method": "POST", "url": "{{base_url}}/study-sessions/start", "body": { "mode": "raw", "raw": "{\n  \"technology_id\": \"{{tech_id}}\"\n}" } },
        { "name": "End", "request": { "method": "PATCH", "url": "{{base_url}}/study-sessions/{{session_id}}/end" } },
        { "name": "Active", "request": { "method": "GET", "url": "{{base_url}}/study-sessions/active" } }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        { "name": "Dashboard", "request": { "method": "GET", "url": "{{base_url}}/analytics/dashboard" } },
        { "name": "User Metrics", "request": { "method": "GET", "url": "{{base_url}}/analytics/user-metrics" } },
        { "name": "Tech Stats", "request": { "method": "GET", "url": "{{base_url}}/analytics/tech-stats" } },
        { "name": "Time Series", "request": { "method": "GET", "url": "{{base_url}}/analytics/time-series?days=30" } },
        { "name": "Weekly", "request": { "method": "GET", "url": "{{base_url}}/analytics/weekly" } },
        { "name": "Heatmap", "request": { "method": "GET", "url": "{{base_url}}/analytics/heatmap?year=2026" } },
        { "name": "Recalculate", "request": { "method": "POST", "url": "{{base_url}}/analytics/recalculate" } },
        { "name": "Export", "request": { "method": "GET", "url": "{{base_url}}/analytics/export?start=2025-01-01&end=2025-01-31", "description": "Exporta dados agregados por dia no período. Parâmetros: start (YYYY-MM-DD), end (YYYY-MM-DD). Máx 366 dias. Throttle: 30/min." } }
      ]
    },
    {
      "name": "System",
      "item": [
        { "name": "Health", "request": { "method": "GET", "url": "http://localhost/api/health" } }
      ]
    }
  ]
}
