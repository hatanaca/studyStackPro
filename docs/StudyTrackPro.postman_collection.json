{
  "info": {
    "name": "StudyTrack Pro API",
    "description": "Endpoints da API StudyTrack Pro",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost/api/v1" },
    { "key": "host", "value": "http://localhost" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "url": "{{host}}/health",
            "description": "Verifica status dos serviços (DB, Redis, Reverb)"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/auth/me",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Novo Nome\",\n  \"timezone\": \"America/Sao_Paulo\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/change-password",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"current_password\": \"password123\",\n  \"password\": \"newpassword123\",\n  \"password_confirmation\": \"newpassword123\"\n}"
            }
          }
        },
        {
          "name": "List Tokens",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/tokens",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Revoke All Tokens",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/auth/tokens",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Technologies",
      "item": [
        {
          "name": "Index",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/technologies",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Search",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/technologies/search?q=vue",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Store",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/technologies",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"TypeScript\",\n  \"slug\": \"typescript\",\n  \"color\": \"#3178C6\",\n  \"is_active\": true\n}"
            }
          }
        },
        {
          "name": "Show",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/technologies/:id",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "urlVariable": [{"key": "id", "value": ""}]
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/technologies/:id",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"TypeScript 5\",\n  \"color\": \"#3178C6\",\n  \"is_active\": true\n}"
            },
            "urlVariable": [{"key": "id", "value": ""}]
          }
        },
        {
          "name": "Destroy",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/technologies/:id",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "urlVariable": [{"key": "id", "value": ""}]
          }
        }
      ]
    },
    {
      "name": "Study Sessions",
      "item": [
        {
          "name": "Index",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/study-sessions?per_page=15",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Active",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/study-sessions/active",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Start",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/study-sessions/start",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"technology_id\": \"{{technology_id}}\"\n}"
            }
          }
        },
        {
          "name": "End",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/study-sessions/:id/end",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "urlVariable": [{"key": "id", "value": ""}]
          }
        },
        {
          "name": "Store",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/study-sessions",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"technology_id\": \"{{technology_id}}\",\n  \"started_at\": \"2025-01-15T10:00:00Z\",\n  \"ended_at\": \"2025-01-15T10:30:00Z\",\n  \"notes\": \"Sessão de revisão\",\n  \"mood\": 4,\n  \"focus_score\": 8\n}"
            }
          }
        },
        {
          "name": "Show",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/study-sessions/:id",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "urlVariable": [{"key": "id", "value": ""}]
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/study-sessions/:id",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"notes\": \"Notas atualizadas\",\n  \"mood\": 5,\n  \"focus_score\": 9\n}"
            },
            "urlVariable": [{"key": "id", "value": ""}]
          }
        },
        {
          "name": "Destroy",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/study-sessions/:id",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "urlVariable": [{"key": "id", "value": ""}]
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/dashboard",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "User Metrics",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/user-metrics",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Tech Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/tech-stats",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Time Series",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/time-series?days=30",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Weekly",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/weekly",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Heatmap",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/analytics/heatmap?year=2025",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Recalculate",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/analytics/recalculate",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    }
  ]
}
