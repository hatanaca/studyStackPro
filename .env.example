# App
APP_NAME=StudyTrackPro
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# PRODUÇÃO (atrás de Nginx/ALB/Cloudflare): IPs ou CIDR separados por vírgula, ou * se só proxies confiáveis falam com a app
# TRUSTED_PROXIES=10.0.0.0/8,172.28.0.0/16
# TRUSTED_PROXIES=*

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=studytrack
DB_USERNAME=studytrack
DB_PASSWORD=secret

# Redis (senha = requirepass em docker/redis/redis.conf)
REDIS_HOST=redis
REDIS_PASSWORD=c812c3a3c4685cda4fc087d6d4edf667
REDIS_PORT=6379

# Cache / Queue / Session (Redis DB numbers)
CACHE_STORE=redis
CACHE_DATABASE=1
QUEUE_CONNECTION=redis
REDIS_QUEUE_DATABASE=2
SESSION_DRIVER=redis
REDIS_SESSION_DATABASE=3
SESSION_COOKIE=studytrack_session
REDIS_HORIZON_DATABASE=4

# Laravel Reverb (WebSocket) - REVERB_HOST=reverb na rede Docker
REVERB_APP_ID=studytrack
REVERB_APP_KEY=local-key
REVERB_APP_SECRET=local-secret
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

# Frontend API (vazio = proxy Vite em dev)
VITE_API_URL=

# Sanctum (SPA: sessão + cookie CSRF; incluir host:porta do Vite)
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:5173,127.0.0.1:5173
# Opcional: expiração do token em minutos (padrão 1440)
# SANCTUM_EXPIRATION=1440

# CORS — com origens definidas, credenciais (cookies) são suportadas para o fluxo Sanctum SPA
CORS_ALLOWED_ORIGINS=http://localhost:5173
