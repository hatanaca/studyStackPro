# API (vazio = usa proxy relativo em dev)
VITE_API_URL=

# Reverb WebSocket
# Defina false para desativar quando o servidor Reverb não estiver rodando
VITE_REVERB_ENABLED=true
# Dev (local): 8080 - porta padrão do Laravel Reverb
# Build/Prod (Nginx): 80 - conecta via proxy do Nginx
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
VITE_REVERB_APP_KEY=local-key
