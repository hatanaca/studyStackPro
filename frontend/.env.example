# API (vazio = usa proxy relativo em dev; o cliente envia credentials para cookies de sessão Sanctum)
VITE_API_URL=
# Backend para o proxy do Vite em dev (padrão: http://127.0.0.1:8000)
# PROXY_TARGET=http://127.0.0.1:8000

# Reverb WebSocket
# Defina false para desativar quando o servidor Reverb não estiver rodando
VITE_REVERB_ENABLED=true
# Dev (local): 8080 - porta padrão do Laravel Reverb
# Build/Prod (Nginx): mesmo host do site, porta 80 ou 443, scheme https — ex. app.example.com + proxy /app/
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
VITE_REVERB_APP_KEY=local-key

# PRODUÇÃO (exemplo): API no mesmo domínio ou subdomínio
# VITE_API_URL=https://api.seu-dominio.com
# VITE_REVERB_HOST=app.seu-dominio.com
# VITE_REVERB_PORT=443
# VITE_REVERB_SCHEME=https
# VITE_REVERB_APP_KEY=<igual a REVERB_APP_KEY no backend>
