{
  "name": "studytrack-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:analyze": "vue-tsc -b && vite build --config vite.config.analyze.ts",
    "preview": "vite preview",
    "test:run": "vitest run --config vitest.config.ts",
    "test": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,js,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,js,css,json}\""
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5",
    "@primeuix/themes": "^2.0.3",
    "@tanstack/vue-query": "^5.59.0",
    "@tanstack/vue-virtual": "^3.13.23",
    "@vue-flow/core": "^1.48.2",
    "@vueuse/core": "^14.2.0",
    "apexcharts": "^5.10.3",
    "axios": "^1.8.2",
    "jspdf": "^4.2.1",
    "laravel-echo": "^2.3.0",
    "pinia": "^2.1.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "pusher-js": "^8.4.0",
    "v-viewer": "^3.0.23",
    "viewerjs": "^1.11.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0",
    "vue3-apexcharts": "^1.11.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.3.0",
    "rollup-plugin-visualizer": "^5.12.0",
    "typescript": "~5.4.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^6.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.0.0"
  }
}
