{
  "name": "studytrack-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:analyze": "vue-tsc -b && vite build --mode analyze",
    "preview": "vite preview",
    "test:run": "vitest run",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.59.0",
    "@vueuse/core": "^14.2.0",
    "apexcharts": "^5.10.3",
    "axios": "^1.6.0",
    "chart.js": "^4.4.0",
    "laravel-echo": "^2.3.0",
    "pinia": "^2.1.0",
    "pusher-js": "^8.4.0",
    "vue": "^3.4.0",
    "vue-chartjs": "^5.3.0",
    "vue-router": "^4.2.0",
    "vue3-apexcharts": "^1.11.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^15.11.7",
    "typescript": "~5.4.0",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "vue-tsc": "^2.0.0",
    "rollup-plugin-visualizer": "^5.12.0"
  }
}
